{
  "$schema": "https://railpack.com/railpack.schema.json",
  "image": "python:3.12-slim",
  "packages": {
    "apt": {
      "runtime": ["poppler-utils", "tesseract-ocr", "tesseract-ocr-chi-sim", "tesseract-ocr-eng"]
    }
  },
  "build": [
    {
      "commands": ["python -m venv /opt/venv", "/opt/venv/bin/pip install -r requirements.txt"]
    }
  ],
  "start": "python app.py",
  "variables": {
    "PATH": "/opt/venv/bin:/usr/local/bin:/usr/bin:/bin"
  }
}
